# Fichiers template .env
# Copier en .env.local et configurer

ENVIRONMENT=development
DEBUG=False
APP_NAME=Prediction Analytics
APP_VERSION=1.0.0

# API
API_HOST=0.0.0.0
API_PORT=8501
API_WORKERS=4

# Database (Optionnel)
DB_HOST=localhost
DB_PORT=5432
DB_USER=app_user
DB_PASS=secure_password
DB_NAME=prediction_db

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALLOW_ORIGINS=localhost,127.0.0.1

# ML Models
MODEL_PATH=/models/model.pkl

# Monitoring
MONITORING_ENABLED=true
METRICS_PORT=9090
